<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_vendor_binding" model="ir.ui.view">
        <field name="name">purchase.order.form.vendor.binding</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='order_line']/list/field[@name='product_id']" position="attributes">
                <attribute name="domain">
                    [
                    ('purchase_ok', '=', True),
                    '|',
                    ('seller_ids.partner_id', '=', parent.partner_id),
                    ('seller_ids', '=', False)
                    ]
                </attribute>
            </xpath>

        </field>
    </record>
    
</odoo>